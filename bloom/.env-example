# How often to run the checks
CHECK_INTERVAL_MINUTES=5

# Time to send the daily report (HH:MM, EST)
DAILY_REPORT_TIME=09:15

# Email notifications
EMAIL_ENABLED=true
SMTP_HOST=smtp.mailgun.org
SMTP_PORT=587
SMTP_USER=postmaster@your-mailgun-sandbox.mailgun.org
SMTP_PASS=your-mailgun-password
SMTP_FROM=website-monitor@yourdomain.com
SMTP_TO=you@yourdomain.com
